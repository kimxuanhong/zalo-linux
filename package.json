{
  "name": "zalo-linux",
  "version": "1.0.0",
  "main": "main.js",
  "private": true,
  "description": "Zalo desktop wrapper for Linux",
  "homepage": "https://chat.zalo.me",
  "author": {
    "name": "Hong Kim",
    "email": "xuanhongkim@gmail.com"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^40.3.0",
    "electron-builder": "^26.7.0"
  },
  "build": {
    "appId": "com.zalo.linux",
    "productName": "Zalo",
    "files": [
      "**/*",
      "!build"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Network",
      "icon": "build/icons",
      "maintainer": "Hong Kim xuanhongkim@gmail.com",
      "desktop": {
        "entry": {
          "Name": "Zalo",
          "Comment": "Zalo Messenger for Linux",
          "GenericName": "Instant Messenger",
          "Keywords": "chat;messenger;zalo;",
          "Categories": "Network;InstantMessaging;",
          "StartupWMClass": "zalo-linux"
        }
      }
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils"
      ]
    }
  }
}